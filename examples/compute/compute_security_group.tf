# =============================================================================
# cloudru_evolution_compute_security_group — Полный пример
# =============================================================================
# Создание группы безопасности в указанной зоне доступности.
# Включены все обязательные и опциональные поля.
# =============================================================================

resource "cloudru_evolution_compute_security_group" "example" {
  project_id = var.project_id

  # Обязательные
  name = "tf-example-security-group"

  zone_identifier = {
    name = "ru.AZ-1"
  }

  # Опциональные
  description = "Пример группы безопасности, созданной через Terraform"
}
