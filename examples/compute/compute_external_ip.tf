# =============================================================================
# cloudru_evolution_compute_external_ip — Полный пример
# =============================================================================
# Создание отдельного публичного IP-адреса.
# Включены все обязательные и опциональные поля.
# =============================================================================

resource "cloudru_evolution_compute_external_ip" "example" {
  project_id = var.project_id

  # Обязательные
  name = "tf-example-external-ip"

  # Опциональные
  description = "Пример публичного IP, созданного через Terraform"

  zone_identifier = {
    name = "ru.AZ-1"
  }
}
