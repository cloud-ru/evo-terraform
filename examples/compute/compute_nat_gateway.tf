# =============================================================================
# cloudru_evolution_compute_nat_gateway — Полный пример
# =============================================================================
# Создание SNAT-шлюза для исходящего доступа в интернет из приватных подсетей.
# Включены все обязательные и опциональные поля.
# =============================================================================

resource "cloudru_evolution_compute_nat_gateway" "example" {
  project_id = var.project_id

  # Обязательные
  name = "tf-example-nat-gateway"

  zone_identifier = {
    name = "ru.AZ-1"
  }

  # Опциональные
  description = "Пример SNAT-шлюза, созданного через Terraform"
  vpc_id      = "57b8f93a-b433-4da9-b24f-87cc69da9afc"
}
